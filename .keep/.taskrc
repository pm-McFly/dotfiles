context.lincompliance.write=+lincompliance

context.HDP.read=+hdp
context.HDP.write=+hdp

context.SmartSLA.read=+smartsla
context.SmartSLA.write=+smartsla

context.SportAide.read=+sportaide
context.SportAide.write=+sportaide

# Files
data.location=~/.task

# Color theme (uncomment one to use)
#include /usr/share/task/light-16.theme
#include /usr/share/task/light-256.theme
#include /usr/share/task/dark-16.theme
#include /usr/share/task/dark-256.theme
#include /usr/share/task/dark-red-256.theme
